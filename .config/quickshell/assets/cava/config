; Doomslayer cava overlay — transparent terminal background
; Path: Doomslayer-mod/.config/quickshell/assets/cava/config
; Launched by: scripts/bash/cava-overlay.sh

[general]
framerate = 60
; keep low enough that first paint survives a half-width map
bars = 36
sensitivity = 100
autosens = 1
lower_cutoff_freq = 50
higher_cutoff_freq = 10000

[input]
method = pipewire
source = auto

[output]
method = ncurses
channels = stereo
mono_option = average
reverse = 0

[color]
; default = transparent (no black box)
background = default
foreground = red
gradient = 1
gradient_count = 3
gradient_color_1 = '#601000'
gradient_color_2 = '#CC2200'
gradient_color_3 = '#FF4500'

[smoothing]
monstercat = 1
waves = 0
noise_reduction = 77
